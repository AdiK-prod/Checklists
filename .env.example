# Supabase — safe for client-side (anon key, RLS enforced)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google sign-in: enable Provider "Google" in Supabase Dashboard → Authentication → Providers.
# Add this URL to Redirect URLs: https://<your-domain>/  (and http://localhost:5173/ for dev).

# After pulling: run `supabase db push` (or apply migrations in SQL editor) so RPC
# `seed_default_templates`, `accept_household_invite`, and tables match the app.

# Anthropic — server-side only (Vercel serverless function)
# DO NOT prefix with VITE_ — must never reach the browser
ANTHROPIC_API_KEY=sk-ant-...
